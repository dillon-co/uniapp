{
  "name": "@uniapp/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "generate": "tsx --tsconfig tsconfig.json node_modules/drizzle-kit/bin.cjs generate",
    "studio": "tsx --tsconfig tsconfig.json node_modules/drizzle-kit/bin.cjs studio",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.0"
  }
}
